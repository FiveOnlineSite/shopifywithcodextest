{% comment %}
  Shop by Concern Testimonial Products
  A self-contained Shopify OS 2.0 section with concern tabs, testimonial content,
  product carousel, and AJAX add-to-cart behavior.
{% endcomment %}

{% liquid
  assign section_heading = section.settings.heading | default: 'Shop by Concern'
%}

<section
  id="ShopByConcern-{{ section.id }}"
  class="sbc-section"
  style="--sbc-bg: {{ section.settings.background_color }}; --sbc-accent: {{ section.settings.accent_color }};"
>
  <div class="sbc-wrap">
    {% if section_heading != blank %}
      <h2 class="sbc-heading">{{ section_heading | escape }}</h2>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="sbc-tabs-wrap" aria-label="Shop by concern selector">
        <button class="sbc-tab-scroll sbc-tab-scroll--prev" type="button" aria-label="Scroll concerns left">
          <span aria-hidden="true">‹</span>
        </button>

        <div class="sbc-tabs" role="tablist">
          {% for block in section.blocks %}
            {% liquid
              assign tab_title = block.settings.tab_title | default: block.settings.active_label_text | default: 'Concern'
              assign label_text = block.settings.active_label_text | default: tab_title
            %}
            <button
              id="sbc-tab-{{ section.id }}-{{ block.id }}"
              class="sbc-tab{% if forloop.first %} is-active{% endif %}"
              type="button"
              role="tab"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-controls="sbc-panel-{{ section.id }}-{{ block.id }}"
              data-sbc-tab="{{ block.id }}"
              {{ block.shopify_attributes }}
            >
              <span class="sbc-tab-image">
                {% if block.settings.tab_image != blank %}
                  {{ block.settings.tab_image | image_url: width: 160 | image_tag: loading: 'lazy', widths: '80, 120, 160', sizes: '80px', alt: tab_title }}
                {% else %}
                  <span class="sbc-tab-placeholder" aria-hidden="true">{{ tab_title | slice: 0 | upcase }}</span>
                {% endif %}
              </span>
              <span class="sbc-tab-label">{{ label_text | escape }}</span>
            </button>
          {% endfor %}
        </div>

        <button class="sbc-tab-scroll sbc-tab-scroll--next" type="button" aria-label="Scroll concerns right">
          <span aria-hidden="true">›</span>
        </button>
      </div>

      <div class="sbc-panels">
        {% for block in section.blocks %}
          {% liquid
            assign tab_title = block.settings.tab_title | default: block.settings.active_label_text | default: 'Concern'
            assign collection = block.settings.collection
            assign explore_link = block.settings.explore_link
            if explore_link == blank and collection != blank
              assign explore_link = collection.url
            endif
          %}

          <div
            id="sbc-panel-{{ section.id }}-{{ block.id }}"
            class="sbc-panel{% if forloop.first %} is-active{% endif %}"
            role="tabpanel"
            aria-labelledby="sbc-tab-{{ section.id }}-{{ block.id }}"
            data-sbc-panel="{{ block.id }}"
            {% unless forloop.first %}hidden{% endunless %}
          >
            <div class="sbc-grid">
              <article class="sbc-testimonial" aria-label="Customer testimonial for {{ tab_title | escape }}">
                <div class="sbc-media">
                  {% if block.settings.testimonial_image != blank %}
                    {{ block.settings.testimonial_image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '360, 540, 720, 900', sizes: '(min-width: 990px) 34vw, 100vw', alt: block.settings.customer_name }}
                  {% else %}
                    <div class="sbc-media-placeholder">
                      <span>Customer image</span>
                    </div>
                  {% endif %}
                </div>

                {% if block.settings.customer_name != blank %}
                  <h3 class="sbc-customer">Hear it from {{ block.settings.customer_name | escape }}</h3>
                {% endif %}

                <div class="sbc-meta" aria-label="Customer details">
                  {% if block.settings.age != blank %}
                    <div class="sbc-meta-item">
                      <span class="sbc-meta-icon" aria-hidden="true"></span>
                      <span><strong>Age</strong>{{ block.settings.age | escape }}</span>
                    </div>
                  {% endif %}

                  {% if block.settings.concern_text != blank %}
                    <div class="sbc-meta-item">
                      <span class="sbc-meta-icon sbc-meta-icon--concern" aria-hidden="true"></span>
                      <span><strong>Concern</strong>{{ block.settings.concern_text | escape }}</span>
                    </div>
                  {% endif %}

                  {% if block.settings.type_text != blank %}
                    <div class="sbc-meta-item">
                      <span class="sbc-meta-icon sbc-meta-icon--type" aria-hidden="true"></span>
                      <span><strong>Type</strong>{{ block.settings.type_text | escape }}</span>
                    </div>
                  {% endif %}
                </div>

                {% if block.settings.quote != blank %}
                  <blockquote class="sbc-quote">“{{ block.settings.quote | escape }}”</blockquote>
                {% endif %}
              </article>

              <div class="sbc-products-area">
                <div class="sbc-products-header">
                  <h3 class="sbc-products-title">Shop the {{ tab_title | escape }} Range</h3>
                  <div class="sbc-carousel-controls" aria-label="Product carousel controls">
                    <button class="sbc-carousel-btn sbc-carousel-btn--prev" type="button" aria-label="Previous products" data-sbc-carousel-prev>
                      <span aria-hidden="true">‹</span>
                    </button>
                    <button class="sbc-carousel-btn sbc-carousel-btn--next" type="button" aria-label="Next products" data-sbc-carousel-next>
                      <span aria-hidden="true">›</span>
                    </button>
                  </div>
                </div>

                {% if collection != blank and collection.products_count > 0 %}
                  <div class="sbc-carousel" data-sbc-carousel>
                    <div class="sbc-product-track" data-sbc-track>
                      {% for product in collection.products limit: section.settings.products_limit %}
                        {% liquid
                          assign current_variant = product.selected_or_first_available_variant
                          assign badge = product.metafields.custom.badge.value | default: product.tags.first
                          assign short_description = product.metafields.custom.short_description.value | default: product.description | strip_html | truncate: 80
                          assign rating_text = product.metafields.reviews.rating.value | default: section.settings.default_rating_text
                        %}
                        <article class="sbc-product-card">
                          <a class="sbc-product-image" href="{{ product.url }}" aria-label="View {{ product.title | escape }}">
                            {% if product.featured_image != blank %}
                              {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', widths: '240, 360, 480, 600', sizes: '(min-width: 990px) 220px, 75vw', alt: product.title }}
                            {% else %}
                              {{ 'product-1' | placeholder_svg_tag: 'sbc-product-placeholder' }}
                            {% endif %}
                            {% if badge != blank %}
                              <span class="sbc-badge">{{ badge | escape }}</span>
                            {% endif %}
                          </a>

                          {% if block.settings.product_label != blank %}
                            <div class="sbc-product-ribbon">{{ block.settings.product_label | escape }}</div>
                          {% endif %}

                          <div class="sbc-product-info">
                            <h4 class="sbc-product-title">
                              <a href="{{ product.url }}">{{ product.title | escape }}</a>
                            </h4>

                            {% if short_description != blank %}
                              <p class="sbc-product-desc">{{ short_description }}</p>
                            {% endif %}

                            {% if rating_text != blank %}
                              <p class="sbc-rating">★ {{ rating_text }}</p>
                            {% endif %}

                            <div class="sbc-price-row">
                              {% if current_variant.compare_at_price > current_variant.price %}
                                <s class="sbc-compare-price">{{ current_variant.compare_at_price | money }}</s>
                              {% endif %}
                              <span class="sbc-price">{{ current_variant.price | money }}</span>
                            </div>
                          </div>

                          <button
                            class="sbc-atc"
                            type="button"
                            data-sbc-add-to-cart
                            data-variant-id="{{ current_variant.id }}"
                            {% unless current_variant.available %}disabled{% endunless %}
                          >
                            {% if current_variant.available %}Add to Cart{% else %}Sold Out{% endif %}
                          </button>
                        </article>
                      {% endfor %}
                    </div>
                  </div>
                {% else %}
                  <div class="sbc-empty">
                    <p>Select a collection for this concern to show products.</p>
                  </div>
                {% endif %}

                {% if explore_link != blank %}
                  <div class="sbc-explore-wrap">
                    <a class="sbc-explore" href="{{ explore_link }}">{{ section.settings.explore_label | escape }}</a>
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="sbc-empty sbc-empty--section">
        <p>Add concern blocks to build this section.</p>
      </div>
    {% endif %}
  </div>
</section>

<style>
  #ShopByConcern-{{ section.id }} {
    background: var(--sbc-bg);
    color: #111111;
    padding: 38px 0 42px;
  }

  #ShopByConcern-{{ section.id }} .sbc-wrap {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 20px;
  }

  #ShopByConcern-{{ section.id }} .sbc-heading {
    margin: 0 0 18px;
    text-align: center;
    font-size: clamp(28px, 4vw, 46px);
    line-height: 0.95;
    font-weight: 900;
    letter-spacing: -0.04em;
    text-transform: uppercase;
  }

  #ShopByConcern-{{ section.id }} .sbc-tabs-wrap {
    display: grid;
    grid-template-columns: 34px minmax(0, 1fr) 34px;
    align-items: center;
    gap: 10px;
    margin-bottom: 28px;
  }

  #ShopByConcern-{{ section.id }} .sbc-tabs {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 28px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    padding: 4px 0 8px;
  }

  #ShopByConcern-{{ section.id }} .sbc-tabs::-webkit-scrollbar {
    display: none;
  }

  #ShopByConcern-{{ section.id }} .sbc-tab {
    position: relative;
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
    gap: 12px;
    min-width: 190px;
    border: 0;
    background: transparent;
    color: rgba(17, 17, 17, 0.35);
    padding: 0;
    cursor: pointer;
    font: inherit;
    text-align: left;
  }

  #ShopByConcern-{{ section.id }} .sbc-tab::before {
    content: "";
    position: absolute;
    inset: 10px 0 8px 48px;
    z-index: 0;
    background: transparent;
    transform: skew(-4deg);
    transition: background-color 180ms ease;
  }

  #ShopByConcern-{{ section.id }} .sbc-tab.is-active {
    color: #111111;
    font-weight: 800;
  }

  #ShopByConcern-{{ section.id }} .sbc-tab.is-active::before {
    background: var(--sbc-accent);
  }

  #ShopByConcern-{{ section.id }} .sbc-tab-image,
  #ShopByConcern-{{ section.id }} .sbc-tab-label {
    position: relative;
    z-index: 1;
  }

  #ShopByConcern-{{ section.id }} .sbc-tab-image {
    width: 74px;
    height: 74px;
    border-radius: 999px;
    overflow: hidden;
    background: #ead7c1;
    display: grid;
    place-items: center;
  }

  #ShopByConcern-{{ section.id }} .sbc-tab-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #ShopByConcern-{{ section.id }} .sbc-tab-placeholder {
    font-weight: 900;
    font-size: 26px;
  }

  #ShopByConcern-{{ section.id }} .sbc-tab-label {
    display: block;
    max-width: 120px;
    font-size: 16px;
    line-height: 1.1;
  }

  #ShopByConcern-{{ section.id }} .sbc-tab-scroll,
  #ShopByConcern-{{ section.id }} .sbc-carousel-btn {
    border: 0;
    border-radius: 999px;
    display: grid;
    place-items: center;
    cursor: pointer;
    transition: transform 160ms ease, opacity 160ms ease;
  }

  #ShopByConcern-{{ section.id }} .sbc-tab-scroll {
    width: 20px;
    height: 20px;
    justify-self: center;
    background: rgba(255, 255, 255, 0.5);
    color: #111111;
    font-size: 20px;
  }

  #ShopByConcern-{{ section.id }} .sbc-carousel-btn:hover,
  #ShopByConcern-{{ section.id }} .sbc-tab-scroll:hover {
    transform: scale(1.04);
  }

  #ShopByConcern-{{ section.id }} .sbc-panel[hidden] {
    display: none;
  }

  #ShopByConcern-{{ section.id }} .sbc-grid {
    display: grid;
    grid-template-columns: minmax(280px, 34%) minmax(0, 1fr);
    gap: 22px;
    align-items: start;
  }

  #ShopByConcern-{{ section.id }} .sbc-media {
    background: #e7d9c4;
    aspect-ratio: 0.93;
    overflow: hidden;
  }

  #ShopByConcern-{{ section.id }} .sbc-media img,
  #ShopByConcern-{{ section.id }} .sbc-media-placeholder {
    width: 100%;
    height: 100%;
  }

  #ShopByConcern-{{ section.id }} .sbc-media img {
    display: block;
    object-fit: cover;
  }

  #ShopByConcern-{{ section.id }} .sbc-media-placeholder {
    display: grid;
    place-items: center;
    color: rgba(17, 17, 17, 0.55);
    font-weight: 700;
  }

  #ShopByConcern-{{ section.id }} .sbc-customer,
  #ShopByConcern-{{ section.id }} .sbc-products-title {
    margin: 14px 0 12px;
    font-size: 18px;
    line-height: 1.2;
    font-weight: 850;
  }

  #ShopByConcern-{{ section.id }} .sbc-meta {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    border-bottom: 1px solid rgba(17, 17, 17, 0.18);
    padding-bottom: 12px;
  }

  #ShopByConcern-{{ section.id }} .sbc-meta-item {
    display: flex;
    gap: 7px;
    align-items: center;
    min-width: 0;
    font-size: 12px;
    line-height: 1.05;
    text-transform: none;
  }

  #ShopByConcern-{{ section.id }} .sbc-meta-item + .sbc-meta-item {
    border-left: 1px solid #8fd9cd;
    padding-left: 10px;
  }

  #ShopByConcern-{{ section.id }} .sbc-meta-item strong {
    display: block;
    font-size: 10px;
    line-height: 1;
    text-transform: uppercase;
    color: rgba(17, 17, 17, 0.55);
    margin-bottom: 2px;
  }

  #ShopByConcern-{{ section.id }} .sbc-meta-icon {
    width: 21px;
    height: 21px;
    border: 1px solid #111111;
    border-radius: 50%;
    position: relative;
    flex: 0 0 auto;
  }

  #ShopByConcern-{{ section.id }} .sbc-meta-icon::after {
    content: "";
    position: absolute;
    width: 10px;
    height: 1px;
    background: #111111;
    bottom: -3px;
    right: -4px;
    transform: rotate(42deg);
  }

  #ShopByConcern-{{ section.id }} .sbc-meta-icon--type {
    background-image: radial-gradient(#111 1px, transparent 1px);
    background-size: 4px 4px;
  }

  #ShopByConcern-{{ section.id }} .sbc-quote {
    position: relative;
    margin: 14px 0 0;
    padding: 12px 14px;
    max-width: 78%;
    background: rgba(179, 235, 220, 0.45);
    font-size: 13px;
    line-height: 1.25;
  }

  #ShopByConcern-{{ section.id }} .sbc-quote::after {
    content: "";
    position: absolute;
    right: -20px;
    top: 0;
    border-top: 46px solid rgba(179, 235, 220, 0.45);
    border-right: 20px solid transparent;
  }

  #ShopByConcern-{{ section.id }} .sbc-products-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }

  #ShopByConcern-{{ section.id }} .sbc-carousel-controls {
    display: flex;
    gap: 10px;
  }

  #ShopByConcern-{{ section.id }} .sbc-carousel-btn {
    width: 30px;
    height: 30px;
    background: #111111;
    color: #ffffff;
    font-size: 30px;
    line-height: 1;
  }

  #ShopByConcern-{{ section.id }} .sbc-carousel-btn--prev {
    background: rgba(17, 17, 17, 0.35);
  }

  #ShopByConcern-{{ section.id }} .sbc-carousel {
    overflow: hidden;
  }

  #ShopByConcern-{{ section.id }} .sbc-product-track {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    padding: 18px 0 6px;
  }

  #ShopByConcern-{{ section.id }} .sbc-product-track::-webkit-scrollbar {
    display: none;
  }

  #ShopByConcern-{{ section.id }} .sbc-product-card {
    flex: 0 0 calc((100% - 48px) / 3);
    scroll-snap-align: start;
    border: 1px solid #111111;
    background: #fbfbf8;
    min-width: 0;
    display: flex;
    flex-direction: column;
  }

  #ShopByConcern-{{ section.id }} .sbc-product-image {
    position: relative;
    display: block;
    aspect-ratio: 1 / 1.08;
    overflow: hidden;
    background: #f2f2ef;
    color: inherit;
    text-decoration: none;
  }

  #ShopByConcern-{{ section.id }} .sbc-product-image img,
  #ShopByConcern-{{ section.id }} .sbc-product-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #ShopByConcern-{{ section.id }} .sbc-badge {
    position: absolute;
    top: 8px;
    right: 8px;
    max-width: calc(100% - 16px);
    border-radius: 999px;
    background: #edc5ed;
    padding: 5px 8px;
    font-size: 10px;
    line-height: 1;
    font-weight: 800;
    text-transform: uppercase;
  }

  #ShopByConcern-{{ section.id }} .sbc-product-ribbon {
    background: #111111;
    color: #ffffff;
    text-align: center;
    padding: 5px 8px;
    font-size: 10px;
    line-height: 1;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  #ShopByConcern-{{ section.id }} .sbc-product-info {
    padding: 10px 8px 8px;
    display: flex;
    flex: 1 1 auto;
    flex-direction: column;
  }

  #ShopByConcern-{{ section.id }} .sbc-product-title {
    margin: 0 0 6px;
    font-size: 13px;
    line-height: 1.15;
    font-weight: 800;
  }

  #ShopByConcern-{{ section.id }} .sbc-product-title a {
    color: inherit;
    text-decoration: none;
  }

  #ShopByConcern-{{ section.id }} .sbc-product-desc,
  #ShopByConcern-{{ section.id }} .sbc-rating {
    margin: 0 0 7px;
    font-size: 10px;
    line-height: 1.25;
  }

  #ShopByConcern-{{ section.id }} .sbc-product-desc {
    color: rgba(17, 17, 17, 0.72);
  }

  #ShopByConcern-{{ section.id }} .sbc-rating {
    margin-top: auto;
  }

  #ShopByConcern-{{ section.id }} .sbc-price-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-size: 13px;
  }

  #ShopByConcern-{{ section.id }} .sbc-compare-price {
    color: rgba(17, 17, 17, 0.42);
    font-size: 11px;
  }

  #ShopByConcern-{{ section.id }} .sbc-price {
    font-weight: 900;
  }

  #ShopByConcern-{{ section.id }} .sbc-atc,
  #ShopByConcern-{{ section.id }} .sbc-explore {
    background: var(--sbc-accent);
    color: #111111;
    border: 0;
    font-weight: 900;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-decoration: none;
  }

  #ShopByConcern-{{ section.id }} .sbc-atc {
    width: calc(100% - 16px);
    margin: 0 8px 8px;
    padding: 12px 10px;
    cursor: pointer;
    font-size: 12px;
  }

  #ShopByConcern-{{ section.id }} .sbc-atc[disabled] {
    opacity: 0.55;
    cursor: not-allowed;
  }

  #ShopByConcern-{{ section.id }} .sbc-explore-wrap {
    display: flex;
    justify-content: center;
    padding-top: 18px;
  }

  #ShopByConcern-{{ section.id }} .sbc-explore {
    display: inline-flex;
    min-width: 142px;
    justify-content: center;
    padding: 11px 18px;
    box-shadow: 0 2px 7px rgba(17, 17, 17, 0.12);
    font-size: 11px;
  }

  #ShopByConcern-{{ section.id }} .sbc-empty {
    border: 1px dashed rgba(17, 17, 17, 0.3);
    padding: 24px;
    text-align: center;
  }

  @media screen and (max-width: 989px) {
    #ShopByConcern-{{ section.id }} .sbc-tabs {
      justify-content: flex-start;
      gap: 18px;
    }

    #ShopByConcern-{{ section.id }} .sbc-grid {
      grid-template-columns: 1fr;
      gap: 26px;
    }

    #ShopByConcern-{{ section.id }} .sbc-product-card {
      flex-basis: calc((100% - 24px) / 2);
    }

    #ShopByConcern-{{ section.id }} .sbc-media {
      aspect-ratio: 1.25;
    }
  }

  @media screen and (max-width: 749px) {
    #ShopByConcern-{{ section.id }} {
      padding: 30px 0 34px;
    }

    #ShopByConcern-{{ section.id }} .sbc-wrap {
      padding: 0 14px;
    }

    #ShopByConcern-{{ section.id }} .sbc-tabs-wrap {
      grid-template-columns: minmax(0, 1fr);
    }

    #ShopByConcern-{{ section.id }} .sbc-tab-scroll {
      display: none;
    }

    #ShopByConcern-{{ section.id }} .sbc-tab {
      min-width: 160px;
      gap: 10px;
    }

    #ShopByConcern-{{ section.id }} .sbc-tab-image {
      width: 62px;
      height: 62px;
    }

    #ShopByConcern-{{ section.id }} .sbc-tab-label {
      max-width: 96px;
      font-size: 14px;
    }

    #ShopByConcern-{{ section.id }} .sbc-products-header {
      align-items: flex-start;
    }

    #ShopByConcern-{{ section.id }} .sbc-product-card {
      flex-basis: 83.333%;
    }

    #ShopByConcern-{{ section.id }} .sbc-meta {
      grid-template-columns: 1fr;
    }

    #ShopByConcern-{{ section.id }} .sbc-meta-item + .sbc-meta-item {
      border-left: 0;
      padding-left: 0;
    }

    #ShopByConcern-{{ section.id }} .sbc-quote {
      max-width: calc(100% - 20px);
    }
  }
</style>

<script>
  (function () {
    var section = document.getElementById('ShopByConcern-{{ section.id }}');
    if (!section || section.dataset.sbcReady === 'true') return;
    section.dataset.sbcReady = 'true';

    var tabs = Array.prototype.slice.call(section.querySelectorAll('[data-sbc-tab]'));
    var panels = Array.prototype.slice.call(section.querySelectorAll('[data-sbc-panel]'));
    var tabsScroller = section.querySelector('.sbc-tabs');

    function setActiveTab(blockId) {
      tabs.forEach(function (tab) {
        var isActive = tab.getAttribute('data-sbc-tab') === blockId;
        tab.classList.toggle('is-active', isActive);
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });

      panels.forEach(function (panel) {
        var isActive = panel.getAttribute('data-sbc-panel') === blockId;
        panel.classList.toggle('is-active', isActive);
        panel.hidden = !isActive;
      });
    }

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        setActiveTab(tab.getAttribute('data-sbc-tab'));
        tab.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      });
    });

    section.querySelectorAll('.sbc-tab-scroll').forEach(function (button) {
      button.addEventListener('click', function () {
        if (!tabsScroller) return;
        var direction = button.classList.contains('sbc-tab-scroll--prev') ? -1 : 1;
        tabsScroller.scrollBy({ left: direction * 220, behavior: 'smooth' });
      });
    });

    section.addEventListener('click', function (event) {
      var carouselButton = event.target.closest('[data-sbc-carousel-prev], [data-sbc-carousel-next]');
      if (carouselButton) {
        var activePanel = section.querySelector('.sbc-panel.is-active');
        var track = activePanel && activePanel.querySelector('[data-sbc-track]');
        if (!track) return;
        var firstCard = track.querySelector('.sbc-product-card');
        var gap = 24;
        var cardWidth = firstCard ? firstCard.getBoundingClientRect().width + gap : track.clientWidth;
        var direction = carouselButton.hasAttribute('data-sbc-carousel-prev') ? -1 : 1;
        track.scrollBy({ left: direction * cardWidth, behavior: 'smooth' });
        return;
      }

      var addButton = event.target.closest('[data-sbc-add-to-cart]');
      if (!addButton || addButton.disabled) return;

      var originalText = addButton.textContent;
      addButton.disabled = true;
      addButton.textContent = 'ADDING…';

      fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify({
          id: Number(addButton.getAttribute('data-variant-id')),
          quantity: 1
        })
      })
        .then(function (response) {
          if (!response.ok) throw new Error('Unable to add item to cart.');
          return response.json();
        })
        .then(function () {
          addButton.textContent = 'ADDED';
          document.dispatchEvent(new CustomEvent('cart:refresh'));
          setTimeout(function () {
            addButton.disabled = false;
            addButton.textContent = originalText.trim() || 'Add to Cart';
          }, 1800);
        })
        .catch(function () {
          addButton.textContent = 'TRY AGAIN';
          setTimeout(function () {
            addButton.disabled = false;
            addButton.textContent = originalText.trim() || 'Add to Cart';
          }, 1800);
        });
    });
  })();
</script>

